
### Interaction Messages

# When trying to eat food without the required utensil... but you gotta hold it
food-you-need-to-hold-utensil = Ви повинні тримати в руках {$utensil}, щоб це з’їсти!

food-nom = Ням. {$flavors}
food-swallow = Ви ковтаєте {$food}. {$flavors}

food-has-used-storage = Ви не можете їсти {$food} з предметом, розташованим всередині.

food-system-remove-mask = Щоб поїсти, спочатку зніміть {$entity}.

food-system-you-cannot-eat-any-more = Ви більше не можете їсти!
food-system-you-cannot-eat-any-more-other = Вони більше не можуть їсти!
food-system-try-use-food-is-empty = {CAPITALIZE(THE($entity))} порожня!
food-system-wrong-utensil = Не можна їсти {THE($food)} з {THE($utensil)}.
food-system-cant-digest = Ви не можете перетравити {THE($entity)}!
food-system-cant-digest-other = Вони не можуть перетравити {THE($entity)}!

food-system-verb-eat = Їсти

food-system-force-feed = {CAPITALIZE(THE($user))} намагається тебе чимось нагодувати!
food-system-force-feed-success = {CAPITALIZE(THE($user))} примусив тебе щось з’їсти! {$flavors}
food-system-force-feed-success-user = Ви успішно годуєте {THE($target)}
