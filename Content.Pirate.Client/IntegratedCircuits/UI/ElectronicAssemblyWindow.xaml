<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
               Resizable="True"
               Title="Electronic Assembly"
               MinSize="850 500">
    <BoxContainer Orientation="Vertical" Margin="5">

        <!-- Header -->
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 5">
            <Label Name="AssemblyNameLabel" Text="Electronic Assembly" StyleClasses="LabelHeading" HorizontalExpand="True" />
            <LineEdit Name="AssemblyNameEdit" Visible="False" HorizontalExpand="True" />
            <Button Name="RenameButton" Text="[Rename]" MinSize="80 0" />
        </BoxContainer>
        
        <BoxContainer Orientation="Horizontal">
            <Label Name="StatsLabel" Text="Space: 0/0 | Complexity: 0/0" HorizontalExpand="True"/>
            <Label Name="BatteryLabel" Text="Power: No Cell" />
            <Button Name="RemoveBatteryButton" Text="[Remove]" MinSize="70 0" Visible="False" Margin="10 0 0 0" />
        </BoxContainer>

        <PanelContainer SetHeight="2" Margin="0 5 0 5">
            <PanelContainer.PanelOverride><gfx:StyleBoxFlat BackgroundColor="#404046" /></PanelContainer.PanelOverride>
        </PanelContainer>

        <!-- Main Split View -->
        <BoxContainer Orientation="Horizontal" VerticalExpand="True">
            
            <!-- LEFT PANEL: Components List -->
            <BoxContainer Orientation="Vertical" MinSize="250 0" Margin="0 0 5 0">
                <Label Text="Installed Components:" StyleClasses="LabelHeading" Margin="0 0 0 5"/>
                <ScrollContainer VerticalExpand="True">
                    <BoxContainer Name="ComponentsList" Orientation="Vertical" />
                </ScrollContainer>
            </BoxContainer>

            <PanelContainer SetWidth="2" Margin="5 0 5 0">
                <PanelContainer.PanelOverride><gfx:StyleBoxFlat BackgroundColor="#404046" /></PanelContainer.PanelOverride>
            </PanelContainer>

            <!-- RIGHT PANEL: Circuit Details -->
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" Name="CircuitDetailsPanel" Visible="False">
                
                <!-- Circuit Header -->
                <BoxContainer Orientation="Horizontal">
                    <Label Name="DetailNameLabel" Text="Circuit Name" StyleClasses="LabelHeading" HorizontalExpand="True"/>
                    <Button Name="RemoveCircuitButton" Text="[Eject]" StyleClasses="ButtonCaution" />
                </BoxContainer>
                <Label Name="DetailDescLabel" Text="Description..." Modulate="Gray" Margin="0 0 0 10"/>

                <!-- The 3-Column Layout for Pins -->
                <BoxContainer Orientation="Horizontal" VerticalExpand="True">
                    <!-- Left: Inputs -->
                    <ScrollContainer HorizontalExpand="True">
                        <BoxContainer Orientation="Vertical">
                            <Label Text="--- Inputs ---" HorizontalAlignment="Center" Modulate="#44AAFF"/>
                            <BoxContainer Name="InputsContainer" Orientation="Vertical" Margin="5"/>
                        </BoxContainer>
                    </ScrollContainer>

                    <!-- Middle: Stats -->
                    <BoxContainer Orientation="Vertical" MinSize="150 0" Margin="10 0 10 0">
                        <Label Text="--- Stats ---" HorizontalAlignment="Center" Modulate="Yellow"/>
                        <Label Name="StatSize" Text="Size: 1"/>
                        <Label Name="StatComp" Text="Complexity: 1"/>
                        <Label Name="StatPower" Text="Power (Idle): 0W"/>
                        <Label Name="StatActive" Text="Power (Act): 0W"/>
                    </BoxContainer>

                    <!-- Right: Outputs -->
                    <ScrollContainer HorizontalExpand="True">
                        <BoxContainer Orientation="Vertical">
                            <Label Text="--- Outputs ---" HorizontalAlignment="Center" Modulate="#44FF44"/>
                            <BoxContainer Name="OutputsContainer" Orientation="Vertical" Margin="5"/>
                        </BoxContainer>
                    </ScrollContainer>
                </BoxContainer>

                <!-- Bottom: Activators -->
                <PanelContainer SetHeight="2" Margin="0 5 0 5"><PanelContainer.PanelOverride><gfx:StyleBoxFlat BackgroundColor="#404046" /></PanelContainer.PanelOverride></PanelContainer>
                <Label Text="--- Activators ---" HorizontalAlignment="Center" Modulate="#FF4444"/>
                <ScrollContainer SetHeight="80">
                    <BoxContainer Name="ActivatorsContainer" Orientation="Vertical" Margin="5"/>
                </ScrollContainer>

            </BoxContainer>
            
            <!-- Placeholder when nothing is selected -->
            <Label Name="SelectPromptLabel" Text="Select a component from the list." HorizontalExpand="True" VerticalAlignment="Center" HorizontalAlignment="Center" Modulate="Gray"/>

        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
