<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="{Loc 'assembly-interact-window-title'}"
               MinSize="300 400">
    <BoxContainer Orientation="Vertical" Margin="5">
        
        <Label Text="{Loc 'assembly-interact-window-prompt'}" Margin="0 0 0 5"/>
        
        <!-- Поле для фільтрації -->
        <LineEdit Name="FilterEdit" PlaceHolder="{Loc 'assembly-interact-window-search-placeholder'}" Margin="0 0 0 5" />

        <!-- Контейнер для списку -->
        <ScrollContainer VerticalExpand="True">
            <BoxContainer Name="OptionsContainer" Orientation="Vertical" />
        </ScrollContainer>
        
    </BoxContainer>
</DefaultWindow>
